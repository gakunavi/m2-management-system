{
  "family": "m2-management-system-b",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::367012942826:role/m2-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::367012942826:role/m2-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "PLACEHOLDER",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "HOSTNAME", "value": "0.0.0.0" },
        { "name": "STORAGE_PROVIDER", "value": "s3" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:367012942826:secret:m2b/database-url-eH5fKy"
        },
        {
          "name": "NEXTAUTH_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:367012942826:secret:m2b/nextauth-url-PUocXi"
        },
        {
          "name": "NEXTAUTH_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:367012942826:secret:m2b/nextauth-secret-xs3Rzx"
        },
        {
          "name": "EMAIL_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:367012942826:secret:m2b/email-api-key-59XfhR"
        },
        {
          "name": "EMAIL_FROM",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:367012942826:secret:m2b/email-from-VjUEcJ"
        },
        {
          "name": "AWS_S3_BUCKET",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:367012942826:secret:m2b/s3-bucket-bFDhFU"
        },
        {
          "name": "CRON_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:367012942826:secret:m2b/cron-secret-pKseDV"
        },
        {
          "name": "VAPID_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:367012942826:secret:m2b/vapid-private-key-Owy4RV"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3000/api/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/m2-management-system-b",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "app"
        }
      }
    }
  ]
}
