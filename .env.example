# ============================================
# M2 Management System - 環境変数設定
# ============================================
# ★ = 必須  ☆ = 任意（デフォルト値あり / 条件付き必須）
#
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
# ============================================

# ============================================
# ★ データベース
# ============================================
# PostgreSQL 接続文字列
# Docker Compose: postgresql://app_user:app_password@localhost:5432/management_system
DATABASE_URL="postgresql://app_user:app_password@localhost:5432/management_system"

# ============================================
# ★ NextAuth.js 認証
# ============================================
# アプリケーションの公開URL（末尾スラッシュなし）
NEXTAUTH_URL="http://localhost:3000"

# セッション暗号化キー（★必須・本番では必ず変更）
# 生成方法: openssl rand -base64 32
# ローテーション: 新しいキーに変更するとすべてのセッションが無効化されます
#   1. メンテナンス時間帯に新キーを設定
#   2. アプリを再起動
#   3. 全ユーザーが再ログインを求められます
NEXTAUTH_SECRET=""

# ============================================
# ☆ Node 環境
# ============================================
# development | production | test
NODE_ENV="development"

# ============================================
# ☆ ファイルストレージ
# ============================================
# local = 開発用（public/uploads/ に保存）
# s3    = 本番用（AWS S3 に保存）
STORAGE_PROVIDER="local"

# AWS S3 設定（STORAGE_PROVIDER=s3 の場合は ★必須）
# AWS_REGION="ap-northeast-1"
# AWS_S3_BUCKET="your-bucket-name"
# AWS_ACCESS_KEY_ID="your-access-key-id"
# AWS_SECRET_ACCESS_KEY="your-secret-access-key"

# ============================================
# ☆ メール通知（将来対応）
# ============================================
# プロバイダー: resend | sendgrid | ses
# EMAIL_PROVIDER="resend"
# EMAIL_FROM="noreply@example.com"
# EMAIL_API_KEY="your-api-key"

# ============================================
# ☆ ログ設定
# ============================================
# ログレベル: error | warn | info | debug
# デフォルト: 開発=debug, 本番=info
# LOG_LEVEL="info"

# ============================================
# ☆ Cron ジョブ保護
# ============================================
# リマインダー通知等の Cron エンドポイントを保護するシークレット
# 生成方法: openssl rand -hex 32
# CRON_SECRET="your-cron-secret"

# ============================================
# ☆ AI アシスタント
# ============================================
# OpenAI API キー（AIアシスタント機能を使用する場合は ★必須）
# 取得: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."
#
# 使用モデル: auto=質問内容で自動切替 / gpt-4o-mini / gpt-4o で固定指定も可
# OPENAI_MODEL="auto"
